<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Stamped" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorSecondaryVariant">@color/brand_accent_dark</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <!-- Material 3 attributes -->
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_card_alt</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_surface</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorTertiary">@color/text_tertiary</item>

        <!-- Типографија -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>

        <!-- Components -->
        <item name="materialButtonStyle">@style/Widget.Stamped.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.Stamped.BottomNav</item>
    </style>

    <style name="Theme.Stamped" parent="Base.Theme.Stamped"/>

    <!-- Onboarding/Login со полна екран ширина -->
    <style name="Theme.Stamped.FullScreen" parent="Base.Theme.Stamped">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.Stamped.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Bottom navigation -->
    <style name="Widget.Stamped.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/bg_card</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Stamped.BottomNav.Indicator</item>
    </style>

    <style name="Widget.Stamped.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/status_wishlist_bg</item>
    </style>

    <!-- Карта стилови -->
    <style name="StampedCard">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
    </style>

    <style name="StampedCardElevated" parent="StampedCard">
        <item name="cardElevation">3dp</item>
    </style>

    <!-- Текст стилови -->
    <style name="TextAppearance.Stamped.Hero" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Stamped.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="TextAppearance.Stamped.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

</resources>
